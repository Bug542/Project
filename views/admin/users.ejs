<h1>Manage Users</h1><table><tr><th>Name</th><th>Email</th><th>Role</th><th>Save</th></tr><% users.forEach(u => { %><tr><td><%= u.first_name %> <%= u.last_name %></td><td><%= u.email %></td><td><form method="post" action="/admin/users/<%= u.user_id %>/role"><select name="role"><option value="user" <%= u.role==='user'?'selected':'' %>>user</option><option value="employee" <%= u.role==='employee'?'selected':'' %>>employee</option><option value="owner" <%= u.role==='owner'?'selected':'' %>>owner</option></select></td><td><button class="btn">Save</button></form></td></tr><% }) %></table>
