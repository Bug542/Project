<h1>Categories</h1><form class="card form" method="post" action="/admin/categories"><label>Category Name<input name="categoryName" required></label><button class="btn">Add Category</button></form><% categories.forEach(c => { %><article class="card row"><span><%= c.category_name %></span><form method="post" action="/admin/categories/<%= c.category_id %>/delete"><button class="danger">Delete</button></form></article><% }) %>
