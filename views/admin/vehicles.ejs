<h1>Owner Inventory</h1><form class="card form" method="post" action="/admin/vehicles"><h2>Add Vehicle</h2><label>Category<select name="categoryId"><% categories.forEach(c => { %><option value="<%= c.category_id %>"><%= c.category_name %></option><% }) %></select></label><label>Make<input name="make" required></label><label>Model<input name="model" required></label><label>Year<input name="year" type="number" required></label><label>Mileage<input name="mileage" type="number" required></label><label>Price<input name="price" type="number" step="0.01" required></label><label>Image URL<input name="imageUrl" placeholder="/images/example.svg or https://..."></label><label>Description<textarea name="description" required></textarea></label><button class="btn">Add Vehicle</button></form><h2>Current Inventory</h2><% vehicles.forEach(v => { %><article class="card row"><span><%= v.year %> <%= v.make %> <%= v.model %> - $<%= Number(v.price).toLocaleString() %></span><form method="post" action="/admin/vehicles/<%= v.vehicle_id %>/delete"><button class="danger">Delete</button></form></article><% }) %>
