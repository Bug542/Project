<h1>Create Account</h1><form class="card form" method="post" action="/register"><label>First Name<input name="firstName" required></label><label>Last Name<input name="lastName" required></label><label>Email<input type="email" name="email" required></label><label>Password<input type="password" name="password" minlength="8" required></label><button class="btn">Register</button></form>
