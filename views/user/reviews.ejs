<h1>My Reviews</h1><% reviews.forEach(r => { %><form class="card form" method="post" action="/account/reviews/<%= r.review_id %>/edit"><h3><%= r.year %> <%= r.make %> <%= r.model %></h3><label>Rating<input type="number" min="1" max="5" name="rating" value="<%= r.rating %>"></label><label>Review<textarea name="reviewText"><%= r.review_text %></textarea></label><button class="btn">Save</button></form><form method="post" action="/account/reviews/<%= r.review_id %>/delete"><button class="danger">Delete</button></form><% }) %>
