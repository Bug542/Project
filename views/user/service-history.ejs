<h1>Service History</h1><a class="btn" href="/account/service-requests/new">New Request</a><table><tr><th>Service</th><th>Vehicle</th><th>Status</th><th>Notes</th><th>Date</th></tr><% requests.forEach(r => { %><tr><td><%= r.service_type %></td><td><%= r.year ? `${r.year} ${r.make} ${r.model}` : 'Not listed' %></td><td><%= r.status %></td><td><%= r.employee_notes || '' %></td><td><%= new Date(r.created_at).toLocaleDateString() %></td></tr><% }) %></table>
