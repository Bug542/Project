<h1>New Service Request</h1><form class="card form" method="post" action="/account/service-requests"><label>Vehicle<select name="vehicleId"><option value="">My own vehicle/not listed</option><% vehicles.forEach(v => { %><option value="<%= v.vehicle_id %>"><%= v.year %> <%= v.make %> <%= v.model %></option><% }) %></select></label><label>Service Type<input name="serviceType" placeholder="Oil change, inspection, repair" required></label><label>Description<textarea name="description" required></textarea></label><button class="btn">Submit Request</button></form>
