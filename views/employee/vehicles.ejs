<h1>Manage Vehicles</h1><% vehicles.forEach(v => { %><form class="card form" method="post" action="/employee/vehicles/<%= v.vehicle_id %>/edit"><h3><%= v.year %> <%= v.make %> <%= v.model %></h3><label>Category<select name="categoryId"><% categories.forEach(c => { %><option value="<%= c.category_id %>" <%= c.category_id === v.category_id ? 'selected' : '' %>><%= c.category_name %></option><% }) %></select></label><label>Make<input name="make" value="<%= v.make %>"></label><label>Model<input name="model" value="<%= v.model %>"></label><label>Year<input name="year" value="<%= v.year %>"></label><label>Mileage<input name="mileage" value="<%= v.mileage %>"></label><label>Price<input name="price" value="<%= v.price %>"></label><label>Availability<select name="availability"><option <%= v.availability==='Available'?'selected':'' %>>Available</option><option <%= v.availability==='Sold'?'selected':'' %>>Sold</option><option <%= v.availability==='Pending'?'selected':'' %>>Pending</option></select></label><label>Description<textarea name="description"><%= v.description %></textarea></label><button class="btn">Save</button></form><% }) %>
