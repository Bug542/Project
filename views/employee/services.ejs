<h1>Service Requests</h1><table><tr><th>User</th><th>Vehicle</th><th>Service</th><th>Status</th><th>Update</th></tr><% requests.forEach(r => { %><tr><td><%= r.first_name %> <%= r.last_name %><br><%= r.email %></td><td><%= r.year ? `${r.year} ${r.make} ${r.model}` : 'Not listed' %></td><td><%= r.service_type %><br><small><%= r.description %></small></td><td><%= r.status %></td><td><form method="post" action="/employee/service-requests/<%= r.request_id %>/update"><select name="status"><option <%= r.status==='Submitted'?'selected':'' %>>Submitted</option><option <%= r.status==='In Progress'?'selected':'' %>>In Progress</option><option <%= r.status==='Completed'?'selected':'' %>>Completed</option></select><textarea name="notes" placeholder="Employee notes"><%= r.employee_notes || '' %></textarea><button class="btn">Update</button></form></td></tr><% }) %></table>
