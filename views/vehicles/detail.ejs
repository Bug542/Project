<section class="vehicle-detail"><div><img class="detail-img" src="<%= images[0]?.image_url || '/images/placeholder.svg' %>" alt="Vehicle image"></div><div><h1><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></h1><p class="price">$<%= Number(vehicle.price).toLocaleString() %></p><p><strong>Category:</strong> <%= vehicle.category_name %></p><p><strong>Mileage:</strong> <%= Number(vehicle.mileage).toLocaleString() %></p><p><strong>Status:</strong> <%= vehicle.availability %></p><p><%= vehicle.description %></p></div></section><section><h2>Reviews</h2><% if (currentUser) { %><form class="card form" method="post" action="/vehicles/<%= vehicle.vehicle_id %>/reviews"><label>Rating<select name="rating"><option>5</option><option>4</option><option>3</option><option>2</option><option>1</option></select></label><label>Review<textarea name="reviewText" required></textarea></label><button class="btn">Add Review</button></form><% } else { %><p><a href="/login">Login</a> to leave a review.</p><% } %><% reviews.forEach(r => { %><article class="card"><strong><%= r.first_name %> <%= r.last_name %></strong><p>Rating: <%= r.rating %>/5</p><p><%= r.review_text %></p></article><% }) %></section>
