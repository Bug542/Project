<h1>Browse Vehicles</h1><form method="get" class="toolbar"><select name="category"><option value="">All Categories</option><% categories.forEach(c => { %><option value="<%= c.category_id %>" <%= String(c.category_id) === String(selectedCategory) ? 'selected' : '' %>><%= c.category_name %></option><% }) %></select><button class="btn">Filter</button></form><div class="grid"><% vehicles.forEach(vehicle => { %><%- include('../partials/vehicle-card', { vehicle }) %><% }) %></div>
