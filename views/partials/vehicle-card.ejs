<article class="card"><img src="<%= vehicle.image_url || '/images/placeholder.svg' %>" alt="<%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %>"><h3><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></h3><p><%= vehicle.category_name %> • <%= Number(vehicle.mileage).toLocaleString() %> miles</p><p class="price">$<%= Number(vehicle.price).toLocaleString() %></p><a class="btn" href="/vehicles/<%= vehicle.vehicle_id %>">View Details</a></article>
